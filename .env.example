# Email delivery (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
FROM_EMAIL=your_verified_sender@example.com

# Scraping config (optional: set proxies to avoid rate-limiting)
HTTP_PROXY=
HTTPS_PROXY=

# Digest schedule (cron syntax, default = 8am daily)
DIGEST_CRON=0 8 * * *

# Comma-separated list of subscriber emails
SUBSCRIBERS=subscriber1@example.com,subscriber2@example.com

# Maximum price threshold — skip tickets above this (USD)
MAX_PRICE_USD=2000
